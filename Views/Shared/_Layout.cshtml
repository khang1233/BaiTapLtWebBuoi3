<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TranMinhKhang_Buoi3</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TranMinhKhang_Buoi3.styles.css" asp-append-version="true" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f3f4f6;
            color: #1f2937;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* Top Line Accent Gradient */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #4f46e5, #7c3aed, #ec4899, #f43f5e);
            z-index: 1050;
        }
        
        /* Modern Glassmorphic Navbar */
        .navbar {
            backdrop-filter: blur(12px) saturate(180%);
            -webkit-backdrop-filter: blur(12px) saturate(180%);
            background-color: rgba(255, 255, 255, 0.8) !important;
            border-bottom: 1px solid rgba(229, 231, 235, 0.5);
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            padding: 15px 0;
            transition: all 0.3s ease;
        }
        
        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #ec4899 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
        }

        .nav-link {
            font-weight: 600;
            color: #4b5563 !important;
            padding: 10px 18px !important;
            border-radius: 12px;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-link:hover {
            color: #4f46e5 !important;
            background-color: rgba(79, 70, 229, 0.08);
            transform: translateY(-1px);
        }

        .nav-link.active-link {
            color: #ffffff !important;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%) !important;
            box-shadow: 0 8px 18px rgba(79, 70, 229, 0.25);
            transform: translateY(-1px);
        }

        main {
            flex-grow: 1;
            padding-top: 15px;
        }

        footer {
            margin-top: auto;
            background: #ffffff;
            border-top: 1px solid rgba(229, 231, 235, 0.6);
            padding: 25px 0;
            box-shadow: 0 -8px 24px rgba(0,0,0,0.02);
            font-size: 0.95rem;
        }

        /* Glassmorphic & Glowing Cards */
        .card-premium {
            background: rgba(255, 255, 255, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.03), 0 5px 15px rgba(0,0,0,0.01);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .card-premium:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(79, 70, 229, 0.08), 0 5px 15px rgba(79, 70, 229, 0.03);
            border-color: rgba(79, 70, 229, 0.2);
        }

        /* Dynamic Gradient Badges */
        .badge-premium {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #ffffff;
            padding: 6px 14px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.8rem;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 10px rgba(79, 70, 229, 0.15);
            border: none;
        }

        /* Premium Buttons with Glowing Gradients */
        .btn-premium-primary {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #ffffff !important;
            border: none;
            border-radius: 12px;
            padding: 12px 24px;
            font-weight: 600;
            font-size: 0.95rem;
            box-shadow: 0 8px 20px rgba(79, 70, 229, 0.25);
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-premium-primary:hover {
            background: linear-gradient(135deg, #4338ca 0%, #6d28d9 100%);
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(79, 70, 229, 0.35);
        }

        .btn-premium-primary:active {
            transform: translateY(0);
        }

        .btn-premium-outline {
            background-color: transparent;
            color: #4f46e5 !important;
            border: 2px solid #4f46e5;
            border-radius: 12px;
            padding: 10px 22px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.25s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-premium-outline:hover {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #ffffff !important;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79, 70, 229, 0.2);
        }

        /* High-quality Premium Form Elements */
        .form-control, .form-select {
            border: 1.5px solid #e5e7eb;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.2s ease;
            background-color: #f9fafb;
        }

        .form-control:focus, .form-select:focus {
            background-color: #ffffff;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
            outline: none;
        }

        /* Animated Hover Tables */
        .table {
            border-collapse: separate;
            border-spacing: 0 8px;
        }

        .table tbody tr {
            background-color: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.01);
            transition: all 0.25s ease;
        }

        .table tbody tr:hover {
            background-color: #f9fafb !important;
            transform: scale(1.005) translateY(-1px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.03);
        }

        .table td, .table th {
            border: none !important;
            padding: 16px 12px !important;
        }

        .table tbody tr td:first-child {
            border-top-left-radius: 12px;
            border-bottom-left-radius: 12px;
        }

        .table tbody tr td:last-child {
            border-top-right-radius: 12px;
            border-bottom-right-radius: 12px;
        }
        
        .table thead tr th {
            padding: 8px 12px !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light sticky-top mb-4">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-rocket-takeoff-fill"></i> TranMinhKhang_Buoi3
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active-link text-white" : "text-dark")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i> Trang Chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active-link text-white" : "text-dark")" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-bag-check-fill me-1"></i> Sản Phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active-link text-white" : "text-dark")" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-grid-fill me-1"></i> Danh Mục
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        <span class="badge bg-light text-primary border border-primary px-3 py-2 rounded-pill font-monospace" style="font-size: 0.9rem;">
                            <i class="bi bi-person-fill"></i> Trần Minh Khang - Buổi 3
                        </span>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="text-muted">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="fw-bold text-dark">TranMinhKhang_Buoi3</span> - Lab 3 ASP.NET Core MVC (Phần 1)
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <span>Sinh viên: <strong>Trần Minh Khang</strong> | MSSV: Buổi 3</span>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
