@model TranMinhKhang_Buoi3.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Edit Product";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="fw-bold m-0 text-dark">Edit Product</h2>
        </div>

        <div class="card card-premium p-4 p-md-5">
            <div class="row g-5">
                <!-- Left Column: Form -->
                <div class="col-md-7 border-end">
                    <form asp-action="Update" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                            <input asp-for="Name" class="form-control py-2" />
                            <span asp-validation-for="Name" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Price" class="form-label fw-semibold text-secondary">Giá Sản Phẩm (VNĐ)</label>
                            <input type="hidden" asp-for="Price" id="priceHidden" />
                            <input type="text" id="priceDisplay" class="form-control py-2" placeholder="Nhập giá sản phẩm (ví dụ: 100.000)" />
                            <span asp-validation-for="Price" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="CategoryId" class="form-label fw-semibold text-secondary">Category</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control py-2"></select>
                            <span asp-validation-for="CategoryId" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ImageUrl" class="form-label fw-semibold text-secondary">Product Image</label>
                            <input type="file" asp-for="ImageUrl" class="form-control py-2" id="imageInput" accept="image/*" />
                            <span asp-validation-for="ImageUrl" class="text-danger" style="font-size: 0.85rem;"></span>
                        </div>

                        <div class="d-flex gap-3">
                            <a asp-action="Index" class="btn btn-light px-4 py-2 rounded-3 text-secondary" style="font-weight: 500;">Back to List</a>
                            <button type="submit" class="btn btn-primary btn-premium-primary px-4 py-2">
                                <i class="bi bi-save"></i> Update
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Right Column: Live Image Preview (Additional requirement v56) -->
                <div class="col-md-5 d-flex flex-column align-items-center justify-content-center text-center">
                    <label class="form-label fw-bold text-secondary mb-3"><i class="bi bi-image"></i> Live Image Preview</label>
                    <div class="border rounded-4 p-3 bg-light d-flex align-items-center justify-content-center shadow-sm overflow-hidden" style="width: 260px; height: 260px;">
                        <img src="@Model.ImageUrl" alt="Product Image" style="max-width: 100%; max-height: 100%; object-fit: contain;" id="previewImage" />
                    </div>
                    <div class="form-text text-muted mt-3"><i class="bi bi-info-circle"></i> Khi bạn chọn một tệp hình ảnh khác, hình ảnh xem trước sẽ ngay lập tức cập nhật trên trang.</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <!-- Dynamic image preview and price formatting script -->
    <script>
        document.getElementById('imageInput').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                    document.getElementById('previewImage').src = event.target.result;
                };
                reader.readAsDataURL(file);
            }
        });

        const priceDisplay = document.getElementById('priceDisplay');
        const priceHidden = document.getElementById('priceHidden');

        function formatNumber(numStr) {
            if (!numStr) return '';
            return numStr.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        if (priceDisplay && priceHidden) {
            // Load and format existing price
            if (priceHidden.value) {
                const rawVal = Math.round(parseFloat(priceHidden.value)).toString();
                priceDisplay.value = formatNumber(rawVal);
            }

            priceDisplay.addEventListener('input', function(e) {
                let rawVal = e.target.value.replace(/\D/g, '');
                e.target.value = formatNumber(rawVal);
                priceHidden.value = rawVal;
            });
        }
    </script>
}
