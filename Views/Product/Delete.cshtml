@model TranMinhKhang_Buoi3.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <!-- Danger Header -->
            <div class="bg-danger text-white p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                <h4 class="fw-bold mt-2 mb-0">Delete Product</h4>
                <p class="m-0 text-white-50 mt-1" style="font-size: 0.9rem;">Hành động này không thể hoàn tác!</p>
            </div>

            <!-- Content Area -->
            <div class="card-body p-4 p-md-5">
                <p class="text-center text-muted mb-4 fs-5">Are you sure you want to delete <strong>@Model.Name</strong>?</p>
                
                <!-- Product Details Box -->
                <div class="d-flex align-items-center gap-3 border rounded-3 p-3 bg-light mb-4">
                    <div style="width: 70px; height: 70px; background-color: #ffffff; display: flex; align-items: center; justify-content: center;" class="border rounded-2 overflow-hidden flex-shrink-0">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="Product thumbnail" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <i class="bi bi-image text-muted" style="font-size: 1.5rem;"></i>
                        }
                    </div>
                    <div>
                        <span class="badge bg-secondary mb-1">@Model.Category?.Name</span>
                        <h6 class="fw-bold m-0 text-dark">@Model.Name</h6>
                        <div class="text-primary fw-semibold" style="font-size: 0.95rem;">@string.Format("{0:N0}", Model.Price) đ</div>
                    </div>
                </div>

                <!-- Action buttons in form -->
                <form asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn btn-light rounded-3 py-2 flex-grow-1 text-secondary" style="font-weight: 500;">Back to List</a>
                        <button type="submit" class="btn btn-danger rounded-3 py-2 flex-grow-1" style="font-weight: 500;">
                            <i class="bi bi-trash-fill"></i> Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
