@model TranMinhKhang_Buoi3.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="fw-bold m-0 text-dark">Chi Tiết Sản Phẩm</h2>
        </div>

        <div class="card card-premium p-4 p-md-5">
            <h2 class="fw-bold text-primary mb-3">@Model.Name</h2>
            
            <div class="border-top border-bottom py-3 mb-4">
                <div class="row">
                    <div class="col-sm-4 text-muted fw-semibold">Giá:</div>
                    <div class="col-sm-8 text-dark fw-bold fs-5">@string.Format("{0:N0}", Model.Price) đ</div>
                </div>
                <div class="row mt-2">
                    <div class="col-sm-4 text-muted fw-semibold">Danh mục:</div>
                    <div class="col-sm-8 text-dark"><span class="badge bg-secondary py-2 px-3">@Model.Category?.Name</span></div>
                </div>
            </div>

            <div class="mb-4">
                <h5 class="fw-semibold text-secondary mb-2">Mô tả:</h5>
                <p class="text-muted" style="white-space: pre-line; line-height: 1.6;">@Model.Description</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-4">
                    <h5 class="fw-semibold text-secondary mb-2">Ảnh sản phẩm:</h5>
                    <div class="border rounded-3 p-2 bg-light d-inline-block shadow-sm">
                        <img src="@Model.ImageUrl" alt="Product Image" style="max-width: 250px; border-radius: 8px;" class="img-fluid" />
                    </div>
                </div>
            }

            <div class="d-flex gap-3 border-top pt-4 mt-4">
                <a asp-action="Index" class="btn btn-light px-4 py-2 rounded-3 text-secondary" style="font-weight: 500;">
                    <i class="bi bi-arrow-left-short"></i> Quay lại Danh sách
                </a>
                <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary btn-premium-primary px-4 py-2">
                    <i class="bi bi-pencil-square"></i> Chỉnh Sửa
                </a>
            </div>
        </div>
    </div>
</div>
