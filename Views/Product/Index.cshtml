@model IEnumerable<TranMinhKhang_Buoi3.Models.Product>

@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0"><i class="bi bi-bag-fill text-primary"></i> Quản Lý Sản Phẩm</h2>
        <p class="text-muted m-0">Danh sách các sản phẩm đang kinh doanh tại cửa hàng</p>
    </div>
    <a asp-action="Add" class="btn-premium-primary">
        <i class="bi bi-plus-circle-fill me-1"></i> Thêm Sản Phẩm Mới
    </a>
</div>

<div class="card card-premium p-0 overflow-hidden">
    <div class="card-header bg-white border-0 p-4">
        <h5 class="fw-bold text-dark m-0">Danh Sách Hàng Hóa</h5>
    </div>

    @if (!Model.Any())
    {
        <div class="p-5 text-center">
            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
            <h5 class="mt-3 text-secondary">Chưa có sản phẩm nào</h5>
            <p class="text-muted mb-3">Nhấp "Thêm Sản Phẩm Mới" ở trên để bắt đầu thêm sản phẩm.</p>
            <a asp-action="Add" class="btn btn-primary">Thêm Sản Phẩm</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle m-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary" style="font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase;">Tên</th>
                        <th class="py-3 text-secondary" style="font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase;">Giá</th>
                        <th class="py-3 text-secondary" style="font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase;">Mô tả</th>
                        <th class="py-3 text-secondary text-center" style="font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase; width: 15%;">Ảnh sản phẩm</th>
                        <th class="py-3 text-secondary" style="font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase; width: 12%;">Loại</th>
                        <th class="py-3 text-secondary text-center" style="font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase; width: 22%;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark fs-6">@product.Name</span>
                            </td>
                            <td>
                                <span class="text-primary fw-semibold font-monospace">@string.Format("{0:N0}", product.Price) đ</span>
                            </td>
                            <td>
                                <p class="text-muted m-0" style="font-size: 0.9rem; max-width: 300px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">
                                    @product.Description
                                </p>
                            </td>
                            <td class="text-center">
                                <div class="d-inline-block border rounded-3 p-1 bg-white shadow-sm overflow-hidden" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover;" class="rounded-2" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-muted" style="font-size: 1.5rem;"></i>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-secondary badge-premium py-2 px-3">@product.Category?.Name</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-primary btn-sm rounded-3 px-3 py-2" style="font-weight: 500;">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-info btn-sm text-white rounded-3 px-3 py-2" style="font-weight: 500; background-color: #0dcaf0; border-color: #0dcaf0;">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm rounded-3 px-3 py-2" style="font-weight: 500;">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
