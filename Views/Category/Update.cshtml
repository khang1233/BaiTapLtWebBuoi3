@model TranMinhKhang_Buoi3.Models.Category

@{
    ViewData["Title"] = "Cập Nhật Danh Mục";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h3 class="fw-bold m-0 text-dark">Cập Nhật Danh Mục</h3>
        </div>

        <div class="card card-premium p-4 p-md-5">
            <form asp-action="Update" method="post" class="needs-validation">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-semibold text-secondary">Tên Danh Mục</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-folder2-open"></i></span>
                        <input asp-for="Name" class="form-control rounded-end-3 py-2" placeholder="Nhập tên danh mục..." />
                    </div>
                    <span asp-validation-for="Name" class="text-danger" style="font-size: 0.85rem;"></span>
                </div>

                <div class="d-flex gap-3">
                    <a asp-action="Index" class="btn btn-light rounded-3 py-2 flex-grow-1 text-secondary" style="font-weight: 500;">Hủy</a>
                    <button type="submit" class="btn btn-primary btn-premium-primary rounded-3 py-2 flex-grow-1">
                        <i class="bi bi-check-lg"></i> Cập Nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
